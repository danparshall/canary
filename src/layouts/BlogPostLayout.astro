---
import BaseLayout from './BaseLayout.astro';

interface Props {
  frontmatter: {
    title: string;
    description?: string;
    date: string;
    author?: string;
    paper?: string;
    area?: 'alignment' | 'economic-impacts';
  };
}

const { frontmatter } = Astro.props;
const base = import.meta.env.BASE_URL;

const areaLabels: Record<string, string> = {
  'alignment': 'Alignment & Control',
  'economic-impacts': 'Economic Impacts',
};

const areaLabel = frontmatter.area ? areaLabels[frontmatter.area] : null;
---

<BaseLayout title={`${frontmatter.title} | The Canary Institute`} description={frontmatter.description}>
  <article class="blog-post">
    <header class="post-header">
      <p class="post-meta">
        {areaLabel && <span class="area-tag">{areaLabel}</span>}
        <time datetime={frontmatter.date}>{new Date(frontmatter.date).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}</time>
        {frontmatter.author && <span> &middot; {frontmatter.author}</span>}
      </p>
      <h1>{frontmatter.title}</h1>
      {frontmatter.description && <p class="post-description">{frontmatter.description}</p>}
      {frontmatter.paper && (
        <p class="post-paper-link">
          This post accompanies a technical paper:
          <a href={frontmatter.paper}>{frontmatter.paper}</a>
        </p>
      )}
    </header>

    <hr />

    <div class="post-body">
      <slot />
    </div>

    <hr />

    <footer class="post-footer">
      <a href={`${base}blog/`}>&larr; Back to all posts</a>
    </footer>
  </article>
</BaseLayout>

<style>
  .post-header {
    margin-bottom: 1rem;
  }

  .post-meta {
    font-size: 0.8rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-light-grey);
    margin-bottom: 0.75rem;
    display: flex;
    align-items: center;
    gap: 0.6rem;
    flex-wrap: wrap;
  }

  .area-tag {
    font-size: 0.65rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-accent);
    border: 1px solid var(--color-accent);
    padding: 0.15rem 0.5rem;
    border-radius: 2px;
  }

  .post-header h1 {
    font-size: 2rem;
    margin-bottom: 0.75rem;
  }

  .post-description {
    font-size: 1.05rem;
    color: var(--color-grey);
    line-height: 1.7;
    font-style: italic;
  }

  .post-paper-link {
    font-size: 0.85rem;
    color: var(--color-light-grey);
    margin-top: 0.75rem;
    padding: 0.75rem 1rem;
    border: 1px solid var(--color-border);
    background: #f4f4f2;
  }

  .post-paper-link a {
    color: var(--color-accent);
    text-decoration: underline;
  }

  .post-body {
    font-size: 1rem;
    line-height: 1.85;
  }

  .post-body :global(h2) {
    margin-top: 2.5rem;
  }

  .post-body :global(h3) {
    margin-top: 2rem;
  }

  .post-body :global(blockquote) {
    border-left: 3px solid var(--color-accent);
    padding-left: 1.25rem;
    margin: 1.5rem 0;
    font-style: italic;
  }

  .post-footer {
    padding-top: 1rem;
  }

  .post-footer a {
    font-size: 0.9rem;
    color: var(--color-accent);
  }
</style>
