---
import BaseLayout from '../../layouts/BaseLayout.astro';

const allPosts = await Astro.glob('./*.md');
const posts = allPosts
  .sort((a, b) => new Date(b.frontmatter.date).getTime() - new Date(a.frontmatter.date).getTime());
---

<BaseLayout title="Blog | The Canary Institute" description="Public-facing analysis and commentary from The Canary Institute on AI safety, capabilities, and policy.">
  <h1>Blog</h1>

  <section class="section">
    <p class="blog-intro">
      For each technical paper we publish, we write a corresponding post here
      that makes the key findings accessible to a general audience. We also
      publish commentary on developments in AI capabilities, safety research,
      and governance as events warrant.
    </p>
  </section>

  {posts.length > 0 ? (
    <section class="section">
      <div class="posts-list">
        {posts.map((post) => (
          <article class="post-preview">
            <p class="post-date">
              <time datetime={post.frontmatter.date}>
                {new Date(post.frontmatter.date).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
              </time>
              {post.frontmatter.paper && <span class="paper-badge">Accompanies paper</span>}
            </p>
            <h2><a href={post.url}>{post.frontmatter.title}</a></h2>
            {post.frontmatter.description && <p class="post-excerpt">{post.frontmatter.description}</p>}
          </article>
        ))}
      </div>
    </section>
  ) : (
    <section class="section">
      <p>Posts are in preparation. Check back soon.</p>
    </section>
  )}
</BaseLayout>

<style>
  .blog-intro {
    font-size: 1rem;
    line-height: 1.8;
    max-width: 38em;
  }

  .posts-list {
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .post-preview {
    padding: 1.75rem 0;
    border-bottom: 1px solid var(--color-border);
  }

  .post-preview:first-child {
    border-top: 1px solid var(--color-border);
  }

  .post-date {
    font-size: 0.78rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-light-grey);
    margin-bottom: 0.4rem;
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .paper-badge {
    font-size: 0.65rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-accent);
    border: 1px solid var(--color-accent);
    padding: 0.15rem 0.5rem;
    border-radius: 2px;
  }

  .post-preview h2 {
    font-size: 1.35rem;
    margin-bottom: 0.4rem;
  }

  .post-preview h2 a {
    color: var(--color-dark);
    text-decoration: none;
  }

  .post-preview h2 a:hover {
    color: var(--color-accent);
  }

  .post-excerpt {
    font-size: 0.92rem;
    line-height: 1.7;
    margin-bottom: 0;
  }
</style>
