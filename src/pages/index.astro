---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="The Canary Institute | AI Safety">
  <section class="hero">
    <h1>The Canary Institute</h1>
    <p class="tagline">For AI Safety</p>
  </section>

  <hr />

  <section class="section">
    <h2>Our Mission</h2>
    <p>
      Craft beer meditation selvage, dreamcatcher sustainable artisan direct trade
      chambray pop-up. We're committed to ensuring artificial intelligence systems
      are developed responsibly, with robust safeguards that protect humanity's
      long-term interests.
    </p>
    <p>
      Typewriter aesthetic pork belly, vexillologist next level brunch pour-over
      ethical. Our interdisciplinary team bridges the gap between technical AI
      research and the policy frameworks needed to govern it.
    </p>
  </section>

  <section class="section">
    <h2>What We Do</h2>
    <p>
      Normcore fixie thundercats, iceland heirloom literally pug selvage cornhole
      chicharrones. We publish peer-reviewed research, advise policymakers, and
      build tools that make AI systems more transparent, interpretable, and aligned
      with human values.
    </p>
  </section>
</BaseLayout>

<style>
  .hero {
    text-align: center;
    padding: 3rem 0 2rem;
  }

  .hero h1 {
    font-size: 2.75rem;
    margin-bottom: 0.5rem;
  }
</style>
