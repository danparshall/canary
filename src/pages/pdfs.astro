---
import BaseLayout from '../layouts/BaseLayout.astro';

const base = import.meta.env.BASE_URL;

const leaveBehinds = [
  {
    title: 'Canary Institute Leave-Behind',
    date: 'April 2026',
    description: 'One-page overview of the Canary Institute, suitable for handing to a policymaker after a meeting.',
    href: `${base}papers/canary-leave-behind-2026-04.pdf`,
  },
  {
    title: 'Navigator',
    date: '',
    description: 'Core Navigator policy framework document.',
    href: `${base}papers/navigator_core.pdf`,
  },
  {
    title: 'Navigator (blog companion)',
    date: '',
    description: 'Companion to the Navigator framework, formatted for blog presentation.',
    href: `${base}papers/navigator_core_blog.pdf`,
  },
  {
    title: 'Half the Economy Is Already in AI’s Reach',
    date: 'June 2026',
    description: 'Task-exposure paper (Parshall & Lopez-Luzuriaga, 2026) introducing a three-axis framework for AI exposure across jobs.',
    href: `${base}papers/Parshall_Lopez-Luzuriaga_TaskExposure_2026.pdf`,
  },
];
---

<BaseLayout
  title="Leave-Behinds | The Canary Institute"
  description="Printable PDFs from the Canary Institute, intended as leave-behinds for policymakers and other contacts."
  noindex={true}
>
  <h1>Leave-Behinds</h1>

  <section class="section">
    <p>
      This page collects printable PDFs from the Canary Institute, intended as
      leave-behinds for policymakers and other contacts. It isn&rsquo;t linked
      from the site navigation; if you have the URL, you have what you need.
    </p>
  </section>

  <section class="section">
    <ul class="pdf-list">
      {leaveBehinds.map(({ title, date, description, href }) => (
        <li>
          <h3>
            <a href={href}>{title}</a>{date && <span class="date"> &mdash; {date}</span>}
          </h3>
          <p>{description}</p>
        </li>
      ))}
    </ul>
  </section>
</BaseLayout>

<style>
  .pdf-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }
  .pdf-list li {
    margin-bottom: 1.5rem;
  }
  .pdf-list h3 {
    margin-bottom: 0.25rem;
  }
  .pdf-list .date {
    font-weight: 400;
    color: var(--color-light-grey);
    font-size: 0.95em;
  }
  .pdf-list p {
    margin-top: 0.25rem;
  }
</style>
