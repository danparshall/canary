---
import BaseLayout from '../layouts/BaseLayout.astro';

const base = import.meta.env.BASE_URL;

// Papers are listed here as data. Each entry becomes a row on the page.
// When a paper is published, add it here and create the corresponding blog post.
// `blog` should match the markdown filename in src/pages/blog/ (without .md).
// `pdf` is optional — link to the actual paper when available.
// `status` is "published" | "forthcoming".

const alignmentPapers: Array<{
  title: string;
  blog?: string;
  pdf?: string;
  date?: string;
  status: string;
  description: string;
}> = [
  // {
  //   title: "Example: Measuring Autonomous Capabilities in Frontier Models",
  //   blog: "measuring-autonomous-capabilities",
  //   pdf: "/papers/measuring-autonomous-capabilities.pdf",
  //   date: "2026-04-15",
  //   status: "published",
  //   description: "An evaluation framework for assessing how close frontier AI systems are to autonomous operation across safety-critical domains.",
  // },
];

const econPapers: Array<{
  title: string;
  blog?: string;
  pdf?: string;
  date?: string;
  status: string;
  description: string;
}> = [
  // {
  //   title: "Example: Near-Term Labor Market Effects of AI-Driven Automation",
  //   blog: "labor-market-effects",
  //   pdf: "/papers/labor-market-effects.pdf",
  //   date: "2026-05-01",
  //   status: "published",
  //   description: "Modeling which sectors and occupations face the most immediate displacement risk, and what that means for policy.",
  // },
];
---

<BaseLayout title="Research | The Canary Institute" description="Technical research on AI alignment and economic impacts from The Canary Institute.">
  <h1>Research</h1>

  <section class="section">
    <p>
      Our research is organized into two programs. Each produces technical
      papers aimed at researchers and policymakers, and each paper is
      accompanied by a
      <a href={`${base}blog/`}>blog post</a> written for a general audience.
      We believe that if a finding matters enough to publish, it matters enough
      to explain.
    </p>
  </section>

  <hr />

  <!-- ── ALIGNMENT ── -->
  <section class="section">
    <div class="area-header">
      <h2>Alignment &amp; Control</h2>
    </div>
    <p>
      Can we keep AI systems pointed in the right direction as they become more
      capable? This program tracks the state of alignment research, evaluates
      frontier model capabilities, and assesses how close we are to the point
      where existing safety techniques may no longer be sufficient. Topics
      include interpretability, autonomous capability evaluations, robustness
      under distributional shift, and the fundamental challenge of maintaining
      oversight over systems that may exceed human cognitive abilities.
    </p>

    {alignmentPapers.length > 0 ? (
      <div class="paper-list">
        <h3>Papers</h3>
        {alignmentPapers.map((p) => (
          <div class="paper-row">
            <div class="paper-info">
              <p class="paper-title">
                {p.pdf ? <a href={p.pdf}>{p.title}</a> : p.title}
              </p>
              <p class="paper-desc">{p.description}</p>
            </div>
            <div class="paper-links">
              {p.date && <span class="paper-date">{p.date}</span>}
              {p.blog && <a href={`${base}blog/${p.blog}/`} class="blog-link">Blog post &rarr;</a>}
              {p.pdf && <a href={p.pdf} class="pdf-link">PDF</a>}
            </div>
          </div>
        ))}
      </div>
    ) : (
      <p class="forthcoming">First papers in preparation.</p>
    )}
  </section>

  <hr />

  <!-- ── ECONOMIC IMPACTS ── -->
  <section class="section">
    <div class="area-header">
      <h2>Economic Impacts</h2>
    </div>
    <p>
      What happens to jobs, wages, and the distribution of wealth as AI
      capabilities accelerate? This program models the near- and medium-term
      economic consequences of AI-driven automation, including labor market
      disruption, productivity effects, sectoral vulnerability, and the
      macroeconomic implications of rapid capability gains. The goal is to give
      policymakers the analysis they need <em>before</em> mass displacement
      occurs, not after.
    </p>

    {econPapers.length > 0 ? (
      <div class="paper-list">
        <h3>Papers</h3>
        {econPapers.map((p) => (
          <div class="paper-row">
            <div class="paper-info">
              <p class="paper-title">
                {p.pdf ? <a href={p.pdf}>{p.title}</a> : p.title}
              </p>
              <p class="paper-desc">{p.description}</p>
            </div>
            <div class="paper-links">
              {p.date && <span class="paper-date">{p.date}</span>}
              {p.blog && <a href={`${base}blog/${p.blog}/`} class="blog-link">Blog post &rarr;</a>}
              {p.pdf && <a href={p.pdf} class="pdf-link">PDF</a>}
            </div>
          </div>
        ))}
      </div>
    ) : (
      <p class="forthcoming">First papers in preparation.</p>
    )}
  </section>
</BaseLayout>

<style>
  .area-header h2 {
    margin-bottom: 1rem;
  }

  .paper-list {
    margin-top: 2rem;
  }

  .paper-list h3 {
    font-family: var(--font-body);
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--color-light-grey);
    margin-bottom: 1rem;
    padding-bottom: 0.5rem;
    border-bottom: 1px solid var(--color-border);
  }

  .paper-row {
    padding: 1.25rem 0;
    border-bottom: 1px solid var(--color-border);
  }

  .paper-title {
    font-family: var(--font-heading);
    font-size: 1.05rem;
    color: var(--color-dark);
    margin-bottom: 0.3rem;
  }

  .paper-title a {
    color: var(--color-dark);
    text-decoration: none;
  }

  .paper-title a:hover {
    color: var(--color-accent);
  }

  .paper-desc {
    font-size: 0.88rem;
    line-height: 1.65;
    color: var(--color-grey);
    margin-bottom: 0.5rem;
  }

  .paper-links {
    display: flex;
    align-items: center;
    gap: 1.25rem;
    margin-top: 0.4rem;
  }

  .paper-date {
    font-size: 0.75rem;
    color: var(--color-light-grey);
    letter-spacing: 0.04em;
  }

  .blog-link {
    font-size: 0.8rem;
    color: var(--color-accent);
    text-decoration: none;
    font-weight: 500;
  }

  .blog-link:hover {
    text-decoration: underline;
  }

  .pdf-link {
    font-size: 0.72rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-light-grey);
    border: 1px solid var(--color-border);
    padding: 0.2rem 0.6rem;
    text-decoration: none;
  }

  .pdf-link:hover {
    color: var(--color-dark);
    border-color: var(--color-dark);
  }

  .forthcoming {
    font-style: italic;
    color: var(--color-light-grey);
    margin-top: 1.5rem;
  }
</style>
