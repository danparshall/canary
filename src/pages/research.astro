---
import BaseLayout from '../layouts/BaseLayout.astro';

const base = import.meta.env.BASE_URL;

// ─── PAPER DATA MODEL ───
// To add a paper:
//   1. Drop the PDF into public/papers/
//   2. Drop the blog post .md into src/pages/blog/
//   3. Add an entry below
//
// Fields:
//   title    — paper title as it appears on arxiv
//   arxiv    — full arxiv URL (e.g. "https://arxiv.org/abs/2406.12345")
//   pdf      — local copy path relative to site root (e.g. "/papers/my-paper.pdf")
//   blog     — slug of the corresponding blog post (filename without .md)
//   date     — publication date (YYYY-MM-DD)
//   description — one-line plain-English summary for the research page

interface Paper {
  title: string;
  arxiv?: string;
  pdf?: string;
  blog?: string;
  abstract?: string;
  date?: string;
  description: string;
}

const alignmentPapers: Paper[] = [
  {
    title: "Bilateral Constitutional AI: Alignment as Navigation Rather Than Value Installation",
    pdf: "papers/navigator_core.pdf",
    blog: "what-if-alignment-is-a-skill",
    date: "2026-02-15",
    description: "Proposes replacing fixed value installation with a democratic navigation architecture where AI alignment is a practiced skill rather than a static state.",
  },
];

const econPapers: Paper[] = [
  {
    title: "Measuring AI's Economic Reach: A Multi-Dimensional Task Taxonomy",
    pdf: "papers/Parshall_Lopez-Luzuriaga_TaskExposure_2026.pdf",
    abstract: "research/task-exposure",
    blog: "measuring-ais-economic-reach",
    date: "2026-03-19",
    description: "A three-axis taxonomy (CDR) separating cognitive complexity, deployment difficulty, and regulatory restrictions to measure where AI's economic impact will land first.",
  },
];
---

<BaseLayout title="Research | The Canary Institute" description="Technical research on AI alignment and economic impacts from The Canary Institute.">
  <h1>Research</h1>

  <section class="section">
    <p>
      Our research is organized into two programs. Each produces technical
      papers aimed at researchers and policymakers, and each paper is
      accompanied by a
      <a href={`${base}blog/`}>blog post</a> written for a general audience.
      We believe that if a finding matters enough to publish, it matters enough
      to explain.
    </p>
  </section>

  <hr />

  <!-- ── ALIGNMENT ── -->
  <section class="section">
    <h2>Alignment &amp; Control</h2>
    <p>
      Can we keep AI systems pointed in the right direction as they become more
      capable? This program tracks the state of alignment research, evaluates
      frontier model capabilities, and assesses how close we are to the point
      where existing safety techniques may no longer be sufficient. Topics
      include interpretability, autonomous capability evaluations, robustness
      under distributional shift, and the fundamental challenge of maintaining
      oversight over systems that may exceed human cognitive abilities.
    </p>

    {alignmentPapers.length > 0 ? (
      <div class="paper-list">
        <h3>Papers</h3>
        {alignmentPapers.map((p) => (
          <div class="paper-row">
            <p class="paper-title">
              {p.abstract ? <a href={`${base}${p.abstract}/`}>{p.title}</a> : p.title}
            </p>
            <p class="paper-desc">{p.description}</p>
            <div class="paper-links">
              {p.date && <span class="paper-date">{p.date}</span>}
              {p.abstract && <a href={`${base}${p.abstract}/`} class="link-blog">Abstract &rarr;</a>}
              {p.blog && <a href={`${base}blog/${p.blog}/`} class="link-blog">Blog post &rarr;</a>}
              {p.arxiv && <a href={p.arxiv} class="link-arxiv" target="_blank" rel="noopener">arXiv</a>}
              {p.pdf && <a href={`${base}${p.pdf}`} class="link-pdf">PDF</a>}
            </div>
          </div>
        ))}
      </div>
    ) : (
      <p class="forthcoming">First papers in preparation.</p>
    )}
  </section>

  <hr />

  <!-- ── ECONOMIC IMPACTS ── -->
  <section class="section">
    <h2>Economic Impacts</h2>
    <p>
      What happens to jobs, wages, and the distribution of wealth as AI
      capabilities accelerate? This program models the near- and medium-term
      economic consequences of AI-driven automation, including labor market
      disruption, productivity effects, sectoral vulnerability, and the
      macroeconomic implications of rapid capability gains. The goal is to give
      policymakers the analysis they need <em>before</em> mass displacement
      occurs, not after.
    </p>

    {econPapers.length > 0 ? (
      <div class="paper-list">
        <h3>Papers</h3>
        {econPapers.map((p) => (
          <div class="paper-row">
            <p class="paper-title">
              {p.abstract ? <a href={`${base}${p.abstract}/`}>{p.title}</a> : p.title}
            </p>
            <p class="paper-desc">{p.description}</p>
            <div class="paper-links">
              {p.date && <span class="paper-date">{p.date}</span>}
              {p.abstract && <a href={`${base}${p.abstract}/`} class="link-blog">Abstract &rarr;</a>}
              {p.blog && <a href={`${base}blog/${p.blog}/`} class="link-blog">Blog post &rarr;</a>}
              {p.arxiv && <a href={p.arxiv} class="link-arxiv" target="_blank" rel="noopener">arXiv</a>}
              {p.pdf && <a href={`${base}${p.pdf}`} class="link-pdf">PDF</a>}
            </div>
          </div>
        ))}
      </div>
    ) : (
      <p class="forthcoming">First papers in preparation.</p>
    )}
  </section>
</BaseLayout>

<style>
  .paper-list {
    margin-top: 2rem;
  }

  .paper-list h3 {
    font-family: var(--font-body);
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--color-light-grey);
    margin-bottom: 1rem;
    padding-bottom: 0.5rem;
    border-bottom: 1px solid var(--color-border);
  }

  .paper-row {
    padding: 1.25rem 0;
    border-bottom: 1px solid var(--color-border);
  }

  .paper-title {
    font-family: var(--font-heading);
    font-size: 1.05rem;
    color: var(--color-dark);
    margin-bottom: 0.3rem;
  }

  .paper-desc {
    font-size: 0.88rem;
    line-height: 1.65;
    color: var(--color-grey);
    margin-bottom: 0.5rem;
  }

  .paper-links {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-top: 0.4rem;
    flex-wrap: wrap;
  }

  .paper-date {
    font-size: 0.75rem;
    color: var(--color-light-grey);
    letter-spacing: 0.04em;
  }

  .link-blog {
    font-size: 0.8rem;
    color: var(--color-accent);
    text-decoration: none;
    font-weight: 500;
  }

  .link-blog:hover {
    text-decoration: underline;
  }

  .link-arxiv,
  .link-pdf {
    font-size: 0.72rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-light-grey);
    border: 1px solid var(--color-border);
    padding: 0.2rem 0.6rem;
    text-decoration: none;
  }

  .link-arxiv:hover,
  .link-pdf:hover {
    color: var(--color-dark);
    border-color: var(--color-dark);
  }

  .forthcoming {
    font-style: italic;
    color: var(--color-light-grey);
    margin-top: 1.5rem;
  }
</style>
