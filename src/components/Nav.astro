---
const currentPath = Astro.url.pathname;
const base = import.meta.env.BASE_URL;

const links = [
  { href: `${base}`, label: 'Home' },
  { href: `${base}about/`, label: 'About' },
  { href: `${base}research/`, label: 'Research' },
  { href: `${base}policy/`, label: 'Policy' },
  { href: `${base}blog/`, label: 'Blog' },
];

function isActive(href: string, current: string): boolean {
  if (href === base) return current === base || current === `${base}/`;
  return current.startsWith(href);
}
---

<header>
  <div class="nav-container container">
    <a href={base} class="logo-link">
      <img src={`${base}canary_base.svg`} alt="The Canary Institute" class="logo" />
    </a>
    <nav>
      {links.map(({ href, label }) => (
        <a
          href={href}
          class:list={[{ active: isActive(href, currentPath) }]}
          aria-current={isActive(href, currentPath) ? 'page' : undefined}
        >
          {label}
        </a>
      ))}
    </nav>
  </div>
</header>

<style>
  header {
    border-bottom: 1px solid var(--color-border);
    background: var(--color-white);
  }

  .nav-container {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: var(--nav-height);
    max-width: var(--max-width);
  }

  .logo-link {
    display: flex;
    align-items: center;
  }

  .logo {
    height: 4rem;
    width: auto;
  }

  nav {
    display: flex;
    gap: 2rem;
  }

  nav a {
    font-family: var(--font-ui);
    font-size: 0.875rem;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    color: var(--color-light-grey);
    transition: color 0.2s;
  }

  nav a:hover,
  nav a.active {
    color: var(--color-dark);
  }

  @media (max-width: 600px) {
    .nav-container {
      flex-direction: column;
      height: auto;
      padding-top: 1rem;
      padding-bottom: 0.75rem;
      gap: 0.75rem;
    }

    nav {
      gap: 1.25rem;
      flex-wrap: wrap;
      justify-content: center;
    }

    nav a {
      font-size: 0.8rem;
    }
  }
</style>
